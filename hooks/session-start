#!/usr/bin/env python3

import json
import sys


def build_session_context() -> str:
    return (
        "<EXTREMELY_IMPORTANT>\n"
        "Use `superpowers-codex:using-superpowers` as the session router before responding.\n"
        "User and repo instructions win over superpowers skills.\n"
        "If you are a dispatched subagent executing a bounded task, skip this session router.\n"
        "</EXTREMELY_IMPORTANT>"
    )


def main() -> int:
    payload = {
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": build_session_context(),
        }
    }

    json.dump(payload, sys.stdout)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
